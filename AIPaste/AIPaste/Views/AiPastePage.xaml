<Page
    x:Class="AIPaste.Views.AiPastePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AIPaste.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:viewmodels="using:AIPaste.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:AiPastePageViewModel}"
    mc:Ignorable="d">

    <Grid Background="#F8F9FA" Margin="10">
        <!-- 行定義 -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <!-- メインコンテンツ（スクロール可能） -->
            <RowDefinition Height="Auto"/>
            <!-- 固定入力エリア -->
        </Grid.RowDefinitions>

        <!-- メインコンテンツ（スクロールビュー内にコピー文章と生成結果を縦並びで配置） -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,10" Spacing="20">
                <!-- コピーした文章 -->
                <StackPanel>
                    <!-- タイトル -->
                    <TextBlock Text="Copy" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="#6C757D" 
                               Margin="0,0,0,8"/>
                    <!-- グレーのタイトル -->

                    <!-- コピー内容 -->
                    <Border BorderBrush="#DEE2E6" BorderThickness="2" CornerRadius="8" Background="#FFFFFF" Padding="15">
                        <TextBlock x:Name="TargetTextBlock" 
                                   TextWrapping="Wrap" 
                                   VerticalAlignment="Top" 
                                   FontSize="16" 
                                   Foreground="#495057"
                                   Text="{x:Bind ViewModel.TargetText, Mode=OneWay}"/>
                    </Border>
                </StackPanel>

                <!-- 生成結果表示 -->
                <StackPanel>
                    <!-- タイトル -->
                    <TextBlock Text="Generated Result" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="#6C757D" 
                               Margin="0,20,0,8"/>
                    <!-- グレーのタイトル -->

                    <!-- 生成結果内容と決定ボタン -->
                    <Border BorderBrush="#DEE2E6" BorderThickness="2" CornerRadius="8" Background="#FFFFFF" Padding="15">
                        <Grid>
                            <!-- 生成結果表示 -->
                            <TextBlock x:Name="OutputTextBlock" 
                                       TextWrapping="Wrap" 
                                       VerticalAlignment="Top"
                                       HorizontalAlignment="Left"
                                       FontSize="16"
                                       Foreground="#495057"
                                       Margin="0,0,0,40"
                                       Text="{x:Bind ViewModel.OutputText, Mode=OneWay}"/>

                            <!-- 決定ボタン -->
                            <Button Content="決定"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Margin="0,10,10,0"
                                    Padding="10,5"
                                    Background="#007BFF"
                                    Foreground="#FFFFFF"
                                    Click="ConfirmButton_Click"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- 入力エリア（常に画面下部に固定） -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- 入力欄 -->
                <ColumnDefinition Width="Auto"/>
                <!-- ボタン -->
            </Grid.ColumnDefinitions>

            <!-- ユーザー入力 -->
            <TextBox x:Name="UserInputBox" Grid.Column="0" Margin="0,0,10,0" PlaceholderText="Enter your prompt here..." AcceptsReturn="True"
                     Background="#FFFFFF"
                     Foreground="#495057"
                     BorderBrush="#CED4DA"
                     FontSize="14"/>

            <!-- 実行ボタン -->
            <Button x:Name="GenerateButton" Grid.Column="1" Content="Generate Text"
                    Background="#007BFF"
                    Foreground="#FFFFFF"
                    FontWeight="Bold"
                    Padding="10,5"
                    Click="GenerateButton_Click"/>
        </Grid>
    </Grid>
</Page>