<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

	<!-- グローバル設定 -->
	<extensions>
		<!-- 必要に応じてカスタムターゲットを追加 -->
	</extensions>

	<!-- ターゲットの定義 -->
	<targets>
		<!-- Traceログ用ファイル -->
		<target xsi:type="File" name="traceFile"
				fileName="${basedir}/logs/trace-${shortdate}.log"
				layout="${longdate} | ${level:uppercase=true} | ${message} ${exception:format=toString,StackTrace}"
				archiveFileName="${basedir}/logs/archive/trace-{#}.log"
				archiveNumbering="Rolling"
				archiveAboveSize="1048576"
			maxArchiveFiles="5"
			encoding="utf-8" />

			<!-- Debugログ用ファイル (開発環境のみ) -->
		<target xsi:type="File" name="debugFile"
				fileName="${basedir}/logs/debug-${shortdate}.log"
				layout="${longdate} | ${level:uppercase=true} | ${message} ${exception:format=toString,StackTrace}"
				archiveFileName="${basedir}/logs/archive/debug-{#}.log"
				archiveNumbering="Rolling"
				archiveAboveSize="1048576"
		maxArchiveFiles="5"
		encoding="utf-8" />

		<!-- Info/Warn/Errorログ用ファイル -->
		<target xsi:type="File" name="infoFile"
				fileName="${basedir}/logs/info-${shortdate}.log"
				layout="${longdate} | ${level:uppercase=true} | ${message} ${exception:format=toString,StackTrace}"
				archiveFileName="${basedir}/logs/archive/info-{#}.log"
				archiveNumbering="Rolling"
				archiveAboveSize="1048576"
		maxArchiveFiles="10"
		encoding="utf-8" />
	</targets>

	<!-- ログルールの定義 -->
	<rules>
		<!-- Traceログ (全環境で有効) -->
		<logger name="*" minlevel="Trace" maxlevel="Trace" writeTo="traceFile" />

		<!-- Debugログ (開発環境のみ) -->
		<logger name="*" minlevel="Debug" writeTo="debugFile" />

		<!-- Info/Warn/Errorログ (全環境で有効) -->
		<logger name="*" minlevel="Info" writeTo="infoFile" />
	</rules>
</nlog>
